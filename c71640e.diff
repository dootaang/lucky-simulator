+    const runtime=new ProjectRuntime(innProject(),7);
+    for(let t=1;t<=150;t++)applyTurn(runtime,turnText(t));
+    const checkpoint=runtime.snapshot(); // 150???쒖젏 ?꾩껜 ?곹깭
