{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SimBot",
  "version": "0.1.0",
  "identifier": "io.simbot.studio",
  "build": {
    "beforeDevCommand": "pnpm --filter @simbot/web dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm --filter @simbot/web build",
    "frontendDist": "../../web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "SimBot",
        "width": 1280,
        "height": 820,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: blob: data:; media-src 'self' asset: blob: data:; connect-src 'self' https: http://localhost:*; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
